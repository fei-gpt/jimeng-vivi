FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your_app_secret
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# Send review/result messages to one target. Use exactly one of these.
FEISHU_CHAT_ID=oc_xxx
FEISHU_BOT_OPEN_ID=

# Feishu/Lark domain. Use open.feishu.cn for China Feishu.
FEISHU_OPENAPI_BASE=https://open.feishu.cn

# WSL/Dreamina defaults.
WSL_DISTRO=Ubuntu-22.04
DEFAULT_DURATION=15
DEFAULT_SCRIPT_DURATION=15
DEFAULT_MODEL=seedance2.0fast_vip
DEFAULT_RATIO=9:16
DEFAULT_RESOLUTION=720p
POLL_SECONDS=300
DEFAULT_JIMENG_ACCOUNT=
JIMENG_ACCOUNT_ROOT=/home/vivi/okivivi/accounts/jimeng

# Default reference-image library for task creation.
IMAGE_LIBRARY_DIR=/home/vivi/okivivi/vivi-image
DEFAULT_IMAGE_VARIANT=blue
DEFAULT_IMAGE_COUNT=2

# Optional remote server image upload.
SERVER_IMAGE_SOURCE_DIR=/home/vivi/okivivi/vivi-image
SERVER_SSH_HOST=
SERVER_SSH_USER=
SERVER_SSH_PORT=22
SERVER_SSH_KEY=
SERVER_IMAGE_REMOTE_DIR=

# DeepSeek script generation.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.9
SCRIPT_AGENT_DOC=/mnt/c/Users/aaa/Documents/okivivi/deepseek/OKIVIVI-text-zong.md
SCRIPT_AGENT_DOCS=/mnt/c/Users/aaa/Documents/okivivi/deepseek/OKIVIVI-text-zong.md;/mnt/c/Users/aaa/Documents/okivivi/deepseek/OKIVIVI-text-assistive.md
DEFAULT_SCRIPT_COUNT=3

# Optional Feishu folder token. If set, newly created bitables/docs are placed in this folder.
FEISHU_DOC_FOLDER_TOKEN=
FEISHU_DOC_BASE=https://ncnrqomkm3wb.feishu.cn

# Optional prompt UI.
PROMPT_UI_HOST=127.0.0.1
PROMPT_UI_PORT=8765
