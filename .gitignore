tasks/*/*
!tasks/*/.gitkeep

# Local/generated prompt samples
prompts/generated/
prompts/manual/
prompts/bitable/

# Large or non-current reference images
vivi-image/animation*.jpg
vivi-image/animation*.png

# OS/editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
typescript
